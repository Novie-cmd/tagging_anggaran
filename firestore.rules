rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: opds
    // Fields: { name: string, code: string, createdAt: timestamp }
    //
    // Collection: tags
    // Fields: { name: string, color: string, type: string, createdAt: timestamp }
    //
    // Collection: programs
    // Fields: { opdId: string, name: string, code: string, createdAt: timestamp }
    //
    // Collection: activities
    // Fields: { programId: string, name: string, code: string, createdAt: timestamp }
    //
    // Collection: subActivities
    // Fields: { activityId: string, name: string, code: string, budget: number, createdAt: timestamp }
    //
    // Collection: budgetTags
    // Fields: { subActivityId: string, tagId: string }
    //
    // Collection: users
    // Fields: { email: string, role: string, displayName: string }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "noviharyanto062@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidOpd() {
      let data = request.resource.data;
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.code is string && data.code.size() > 0 && data.code.size() < 50;
    }

    function isValidTag() {
      let data = request.resource.data;
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.color is string && data.color.matches("^#[0-9a-fA-F]{6}$") &&
             data.type in ['Daerah', 'Prioritas Nasional'];
    }

    function isValidProgram() {
      let data = request.resource.data;
      return data.opdId is string && data.name is string && data.code is string;
    }

    function isValidActivity() {
      let data = request.resource.data;
      return data.programId is string && data.name is string && data.code is string;
    }

    function isValidSubActivity() {
      let data = request.resource.data;
      return data.activityId is string && data.name is string && data.code is string && data.budget is number && data.budget >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
    }

    match /opds/{opdId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidOpd();
      allow delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidTag();
      allow delete: if isAdmin();
    }

    match /programs/{programId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidProgram();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidActivity();
      allow delete: if isAdmin();
    }

    match /subActivities/{subActivityId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidSubActivity();
      allow delete: if isAdmin();
    }

    match /budgetTags/{tagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
